# Copy to .env and adjust if needed. Local Docker Compose defaults (see repo root docker-compose.yml).
DATABASE_URL="postgresql://lifa:lifa_dev_password@localhost:5432/lifa_dev?schema=public"

# Auth — change JWT_SECRET to a long random string in any non-dev environment.
JWT_SECRET="dev-only-secret-replace-me-with-a-long-random-string"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"
