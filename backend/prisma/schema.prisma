// LiFa — MVP Prisma schema.
// Conventions:
//   - Prisma model fields use camelCase; DB columns use snake_case via @map.
//   - All money values are Decimal(19,4). Never float.
//   - Every business table is company-scoped (company_id FK).
//   - Document numbers (invoice_number, entry_number) are NULL while draft,
//     assigned only on issue/post via the DocumentSequence table.
//   - Posted journal entries are immutable. Voids are reversal entries that
//     also stay POSTED; status enum has only DRAFT and POSTED.
// See IMPLEMENTATION_PLAN.md Step 2 for the full specification.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum LegalForm {
  BI
  OP
  KO
  SHPK
  SHA
  FOREIGN_BRANCH
  NGO
  OTHER
}

enum AddressType {
  REGISTERED
  BUSINESS
  OTHER
}

enum ActivityType {
  PRIMARY
  SECONDARY
}

enum AccountRole {
  ACCOUNTS_RECEIVABLE
  CASH
  BANK
  VAT_PAYABLE
  SALES_REVENUE
}

enum ProductServiceType {
  PRODUCT
  SERVICE
}

enum TaxCalculationType {
  EXCLUSIVE
  INCLUSIVE
}

enum TaxScope {
  SALES
  PURCHASES
  BOTH
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentType {
  RECEIVED
  MADE // reserved for post-MVP (purchase payments); MVP issues RECEIVED only
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  RECORDED
  VOID
}

enum JournalEntryStatus {
  DRAFT
  POSTED
}

enum DocumentType {
  INVOICE
  JOURNAL_ENTRY
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ---------------------------------------------------------------------------
// Platform / Auth
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(uuid()) @db.Uuid
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  companyAccess     UserCompanyAccess[]
  createdCompanies  Company[]              @relation("CompanyCreatedBy")
  createdContacts   Contact[]              @relation("ContactCreatedBy")
  createdProducts   ProductService[]       @relation("ProductCreatedBy")
  createdAccounts   Account[]              @relation("AccountCreatedBy")
  closedPeriods     AccountingPeriod[]     @relation("PeriodClosedBy")
  postedJournals    JournalEntry[]         @relation("JournalPostedBy")
  createdJournals   JournalEntry[]         @relation("JournalCreatedBy")
  createdInvoices   Invoice[]              @relation("InvoiceCreatedBy")
  createdPayments   Payment[]              @relation("PaymentCreatedBy")
  createdAllocs     PaymentAllocation[]    @relation("AllocationCreatedBy")
  auditLogs         AuditLog[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique // owner | admin | accountant | viewer
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userCompanyAccess UserCompanyAccess[]

  @@map("roles")
}

model UserCompanyAccess {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("user_company_access")
}

// ---------------------------------------------------------------------------
// Company
// ---------------------------------------------------------------------------

model Company {
  id                    String    @id @default(uuid()) @db.Uuid
  legalName             String    @map("legal_name")
  tradeName             String?   @map("trade_name")
  legalForm             LegalForm @map("legal_form")
  uinNui                String?   @map("uin_nui")
  fiscalNumber          String?   @map("fiscal_number")
  vatNumber             String?   @map("vat_number")
  registrationDate      DateTime? @map("registration_date") @db.Date
  email                 String?
  phone                 String?
  website               String?
  defaultCurrency       String    @default("EUR") @map("default_currency")
  fiscalYearStartMonth  Int       @default(1) @map("fiscal_year_start_month")
  createdBy             String    @map("created_by") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  creator           User                     @relation("CompanyCreatedBy", fields: [createdBy], references: [id])
  userAccess        UserCompanyAccess[]
  addresses         CompanyAddress[]
  activityCodes     CompanyActivityCode[]
  accountDefaults   CompanyAccountDefaults[]
  contacts          Contact[]
  productsServices  ProductService[]
  taxRates          TaxRate[]
  accounts          Account[]
  periods           AccountingPeriod[]
  journalEntries    JournalEntry[]
  invoices          Invoice[]
  payments          Payment[]
  documentSequences DocumentSequence[]
  auditLogs         AuditLog[]

  @@map("companies")
}

model CompanyAddress {
  id          String      @id @default(uuid()) @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  addressType AddressType @map("address_type")
  country     String?
  municipality String?
  city        String?
  street      String?
  postalCode  String?     @map("postal_code")
  isPrimary   Boolean     @default(false) @map("is_primary")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_addresses")
}

model CompanyActivityCode {
  id           String       @id @default(uuid()) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  activityType ActivityType @map("activity_type")
  code         String
  description  String?
  sortOrder    Int          @default(0) @map("sort_order")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_activity_codes")
}

model CompanyAccountDefaults {
  id          String      @id @default(uuid()) @db.Uuid
  companyId   String      @map("company_id") @db.Uuid
  accountRole AccountRole @map("account_role")
  accountId   String      @map("account_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@unique([companyId, accountRole])
  @@index([companyId])
  @@map("company_account_defaults")
}

// ---------------------------------------------------------------------------
// Contacts
// ---------------------------------------------------------------------------

// CHECK (is_customer = true OR is_vendor = true) is enforced via raw SQL
// added to the initial migration — Prisma does not support CHECK constraints.
model Contact {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  isCustomer        Boolean  @default(false) @map("is_customer")
  isVendor          Boolean  @default(false) @map("is_vendor")
  displayName       String   @map("display_name")
  legalName         String?  @map("legal_name")
  email             String?
  phone             String?
  taxId             String?  @map("tax_id")
  paymentTermsDays  Int?     @map("payment_terms_days")
  currency          String   @default("EUR")
  country           String?
  municipality      String?
  city              String?
  street            String?
  postalCode        String?  @map("postal_code")
  isActive          Boolean  @default(true) @map("is_active")
  notes             String?
  createdBy         String   @map("created_by") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator          User               @relation("ContactCreatedBy", fields: [createdBy], references: [id])
  invoices         Invoice[]
  payments         Payment[]
  journalEntryLines JournalEntryLine[]

  @@index([companyId])
  @@index([companyId, isCustomer])
  @@index([companyId, isVendor])
  @@map("contacts")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model ProductService {
  id                String             @id @default(uuid()) @db.Uuid
  companyId         String             @map("company_id") @db.Uuid
  type              ProductServiceType
  sku               String?
  name              String
  description       String?
  unit              String?
  salePrice         Decimal?           @map("sale_price") @db.Decimal(19, 4)
  purchasePrice     Decimal?           @map("purchase_price") @db.Decimal(19, 4)
  incomeAccountId   String?            @map("income_account_id") @db.Uuid
  expenseAccountId  String?            @map("expense_account_id") @db.Uuid
  defaultTaxRateId  String?            @map("default_tax_rate_id") @db.Uuid
  isActive          Boolean            @default(true) @map("is_active")
  createdBy         String             @map("created_by") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator        User          @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  incomeAccount  Account?      @relation("ProductIncomeAccount", fields: [incomeAccountId], references: [id])
  expenseAccount Account?      @relation("ProductExpenseAccount", fields: [expenseAccountId], references: [id])
  defaultTaxRate TaxRate?      @relation(fields: [defaultTaxRateId], references: [id])
  invoiceLines   InvoiceLine[]

  @@index([companyId])
  @@map("products_services")
}

// ---------------------------------------------------------------------------
// Tax
// ---------------------------------------------------------------------------

// company_id is nullable here because system-level tax rate templates
// (Standard 18%, Reduced 8%, Zero/Exempt 0%) live with company_id = NULL
// and are copied per-company during CompanySetupService.seedDefaults.
model TaxRate {
  id              String             @id @default(uuid()) @db.Uuid
  companyId       String?            @map("company_id") @db.Uuid
  name            String
  code            String
  rate            Decimal            @db.Decimal(19, 4)
  calculationType TaxCalculationType @map("calculation_type")
  scope           TaxScope
  isDefault       Boolean            @default(false) @map("is_default")
  isActive        Boolean            @default(true) @map("is_active")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  company         Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  productsServices ProductService[]
  invoiceLines    InvoiceLine[]

  @@index([companyId])
  @@map("tax_rates")
}

// ---------------------------------------------------------------------------
// Accounting
// ---------------------------------------------------------------------------

model Account {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @map("company_id") @db.Uuid
  code            String
  name            String
  accountType     AccountType   @map("account_type")
  accountSubtype  String?       @map("account_subtype")
  normalBalance   NormalBalance @map("normal_balance")
  parentAccountId String?       @map("parent_account_id") @db.Uuid
  isPostable      Boolean       @default(true) @map("is_postable")
  isSystem        Boolean       @default(false) @map("is_system")
  isActive        Boolean       @default(true) @map("is_active")
  createdBy       String        @map("created_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  company             Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator             User                     @relation("AccountCreatedBy", fields: [createdBy], references: [id])
  parentAccount       Account?                 @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts       Account[]                @relation("AccountHierarchy")
  journalEntryLines   JournalEntryLine[]
  productsIncome      ProductService[]         @relation("ProductIncomeAccount")
  productsExpense     ProductService[]         @relation("ProductExpenseAccount")
  invoiceLinesIncome  InvoiceLine[]
  companyDefaults     CompanyAccountDefaults[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("accounts")
}

model AccountingPeriod {
  id           String       @id @default(uuid()) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  fiscalYear   Int          @map("fiscal_year")
  periodNumber Int          @map("period_number")
  startDate    DateTime     @map("start_date") @db.Date
  endDate      DateTime     @map("end_date") @db.Date
  status       PeriodStatus @default(OPEN)
  closedAt     DateTime?    @map("closed_at")
  closedBy     String?      @map("closed_by") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  closedByUser  User?          @relation("PeriodClosedBy", fields: [closedBy], references: [id])
  journalEntries JournalEntry[]

  @@unique([companyId, fiscalYear, periodNumber])
  @@index([companyId])
  @@map("accounting_periods")
}

// Unique constraint on (companyId, entryNumber) is implemented as a PARTIAL
// index (WHERE entry_number IS NOT NULL) via raw SQL in the initial migration —
// Prisma does not support partial unique indexes.
model JournalEntry {
  id                  String             @id @default(uuid()) @db.Uuid
  companyId           String             @map("company_id") @db.Uuid
  entryNumber         String?            @map("entry_number") // null while DRAFT, set on POST
  entryDate           DateTime           @map("entry_date") @db.Date
  periodId            String?            @map("period_id") @db.Uuid // assigned on post
  sourceDocumentType  String?            @map("source_document_type") // MANUAL | INVOICE | PAYMENT | INVOICE_VOID | PAYMENT_VOID
  sourceDocumentId    String?            @map("source_document_id") @db.Uuid
  memo                String?
  status              JournalEntryStatus @default(DRAFT)
  postedAt            DateTime?          @map("posted_at")
  postedBy            String?            @map("posted_by") @db.Uuid
  reversalOfEntryId   String?            @map("reversal_of_entry_id") @db.Uuid // set on reversal entries
  reversedByEntryId   String?            @unique @map("reversed_by_entry_id") @db.Uuid // set on original when reversed
  createdBy           String             @map("created_by") @db.Uuid
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator         User              @relation("JournalCreatedBy", fields: [createdBy], references: [id])
  postedByUser    User?             @relation("JournalPostedBy", fields: [postedBy], references: [id])
  period          AccountingPeriod? @relation(fields: [periodId], references: [id])
  reversalOf      JournalEntry?     @relation("JournalReversal", fields: [reversalOfEntryId], references: [id])
  reversalEntries JournalEntry[]    @relation("JournalReversal")
  reversedBy      JournalEntry?     @relation("JournalReversedBy", fields: [reversedByEntryId], references: [id])
  reversesEntry   JournalEntry?     @relation("JournalReversedBy")
  lines           JournalEntryLine[]
  postedInvoices  Invoice[]         @relation("InvoicePostedEntry")
  voidedInvoices  Invoice[]         @relation("InvoiceVoidedEntry")
  postedPayments  Payment[]         @relation("PaymentPostedEntry")
  voidedPayments  Payment[]         @relation("PaymentVoidedEntry")

  @@index([companyId])
  @@index([companyId, entryDate, status])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String   @id @default(uuid()) @db.Uuid
  journalEntryId String   @map("journal_entry_id") @db.Uuid
  lineNumber     Int      @map("line_number")
  accountId      String   @map("account_id") @db.Uuid
  description    String?
  debitAmount    Decimal  @default(0) @map("debit_amount") @db.Decimal(19, 4)
  creditAmount   Decimal  @default(0) @map("credit_amount") @db.Decimal(19, 4)
  currency       String   @default("EUR")
  exchangeRate   Decimal  @default(1) @map("exchange_rate") @db.Decimal(19, 4)
  contactId      String?  @map("contact_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  contact      Contact?     @relation(fields: [contactId], references: [id])

  @@index([journalEntryId, accountId])
  @@map("journal_entry_lines")
}

// ---------------------------------------------------------------------------
// Sales
// ---------------------------------------------------------------------------

// Unique constraint on (companyId, invoiceNumber) is implemented as a PARTIAL
// index (WHERE invoice_number IS NOT NULL) via raw SQL in the initial migration.
model Invoice {
  id                     String        @id @default(uuid()) @db.Uuid
  companyId              String        @map("company_id") @db.Uuid
  invoiceNumber          String?       @map("invoice_number") // null while DRAFT, set on ISSUE
  contactId              String        @map("contact_id") @db.Uuid
  issueDate              DateTime      @map("issue_date") @db.Date
  dueDate                DateTime      @map("due_date") @db.Date
  currency               String        @default("EUR")
  exchangeRate           Decimal       @default(1) @map("exchange_rate") @db.Decimal(19, 4)
  subtotalAmount         Decimal       @default(0) @map("subtotal_amount") @db.Decimal(19, 4)
  taxAmount              Decimal       @default(0) @map("tax_amount") @db.Decimal(19, 4)
  totalAmount            Decimal       @default(0) @map("total_amount") @db.Decimal(19, 4)
  paidAmount             Decimal       @default(0) @map("paid_amount") @db.Decimal(19, 4)
  balanceDue             Decimal       @default(0) @map("balance_due") @db.Decimal(19, 4)
  status                 InvoiceStatus @default(DRAFT)
  notes                  String?
  postedJournalEntryId   String?       @map("posted_journal_entry_id") @db.Uuid
  voidedJournalEntryId   String?       @map("voided_journal_entry_id") @db.Uuid
  createdBy              String        @map("created_by") @db.Uuid
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator             User                @relation("InvoiceCreatedBy", fields: [createdBy], references: [id])
  contact             Contact             @relation(fields: [contactId], references: [id])
  postedJournalEntry  JournalEntry?       @relation("InvoicePostedEntry", fields: [postedJournalEntryId], references: [id])
  voidedJournalEntry  JournalEntry?       @relation("InvoiceVoidedEntry", fields: [voidedJournalEntryId], references: [id])
  lines               InvoiceLine[]
  paymentAllocations  PaymentAllocation[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("invoices")
}

model InvoiceLine {
  id              String        @id @default(uuid()) @db.Uuid
  invoiceId       String        @map("invoice_id") @db.Uuid
  lineNumber      Int           @map("line_number")
  productServiceId String?      @map("product_service_id") @db.Uuid
  description     String?
  quantity        Decimal       @db.Decimal(19, 4)
  unitPrice       Decimal       @map("unit_price") @db.Decimal(19, 4)
  discountType    DiscountType? @map("discount_type")
  discountValue   Decimal?      @map("discount_value") @db.Decimal(19, 4)
  taxRateId       String?       @map("tax_rate_id") @db.Uuid
  netAmount       Decimal       @default(0) @map("net_amount") @db.Decimal(19, 4)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(19, 4)
  totalAmount     Decimal       @default(0) @map("total_amount") @db.Decimal(19, 4)
  incomeAccountId String?       @map("income_account_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  invoice        Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productService ProductService? @relation(fields: [productServiceId], references: [id])
  taxRate        TaxRate?        @relation(fields: [taxRateId], references: [id])
  incomeAccount  Account?        @relation(fields: [incomeAccountId], references: [id])

  @@index([invoiceId])
  @@map("invoice_lines")
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

model Payment {
  id                     String        @id @default(uuid()) @db.Uuid
  companyId              String        @map("company_id") @db.Uuid
  contactId              String        @map("contact_id") @db.Uuid
  paymentType            PaymentType   @map("payment_type")
  paymentMethod          PaymentMethod @map("payment_method")
  paymentDate            DateTime      @map("payment_date") @db.Date
  referenceNumber        String?       @map("reference_number")
  currency               String        @default("EUR")
  exchangeRate           Decimal       @default(1) @map("exchange_rate") @db.Decimal(19, 4)
  totalAmount            Decimal       @map("total_amount") @db.Decimal(19, 4)
  status                 PaymentStatus @default(RECORDED)
  notes                  String?
  postedJournalEntryId   String?       @map("posted_journal_entry_id") @db.Uuid
  voidedJournalEntryId   String?       @map("voided_journal_entry_id") @db.Uuid
  createdBy              String        @map("created_by") @db.Uuid
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  company             Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  creator             User                @relation("PaymentCreatedBy", fields: [createdBy], references: [id])
  contact             Contact             @relation(fields: [contactId], references: [id])
  postedJournalEntry  JournalEntry?       @relation("PaymentPostedEntry", fields: [postedJournalEntryId], references: [id])
  voidedJournalEntry  JournalEntry?       @relation("PaymentVoidedEntry", fields: [voidedJournalEntryId], references: [id])
  allocations         PaymentAllocation[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("payments")
}

model PaymentAllocation {
  id              String   @id @default(uuid()) @db.Uuid
  paymentId       String   @map("payment_id") @db.Uuid
  invoiceId       String   @map("invoice_id") @db.Uuid
  allocatedAmount Decimal  @map("allocated_amount") @db.Decimal(19, 4)
  allocationDate  DateTime @map("allocation_date") @db.Date
  isVoided        Boolean  @default(false) @map("is_voided")
  voidedAt        DateTime? @map("voided_at")
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  creator User    @relation("AllocationCreatedBy", fields: [createdBy], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
  @@map("payment_allocations")
}

// ---------------------------------------------------------------------------
// Document Sequencing
// ---------------------------------------------------------------------------

// All three columns are NON-NULLABLE, so a standard unique constraint is safe
// (no partial-index workaround needed).
model DocumentSequence {
  id           String       @id @default(uuid()) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  documentType DocumentType @map("document_type")
  fiscalYear   Int          @map("fiscal_year")
  prefix       String
  lastNumber   Int          @default(0) @map("last_number")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, documentType, fiscalYear])
  @@index([companyId])
  @@map("document_sequences")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  action     String
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  occurredAt DateTime @default(now()) @map("occurred_at")
  ipAddress  String?  @map("ip_address")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([companyId, entityType, entityId])
  @@map("audit_logs")
}
